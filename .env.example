# Configurações do Firebase (Frontend - Vite)
# Copie este arquivo para .env e substitua pelos seus valores reais

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# ====================================================
# Configurações da API Serverless (Vercel)
# Adicione estas variáveis no painel da Vercel também!
# ====================================================

# Token secreto para autenticar requisições na API.
# Gere um token forte e único. Ex: openssl rand -hex 32
API_SECRET_TOKEN=your_strong_secret_token_here

# Origens CORS permitidas (separadas por vírgula).
# Inclua o domínio da Vercel e o domínio do sistema parceiro.
# Se não definido, somente o domínio padrão da Vercel será aceito.
# Requisições server-to-server (sem header Origin) são sempre aceitas se o token for válido.
ALLOWED_ORIGINS=https://meu-app-formulario.vercel.app,https://sistema-parceiro.exemplo.com

# Credenciais Firebase Admin SDK (para a API Serverless)
# Opção A: JSON completo da Service Account (recomendado)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
# Opção B: Variáveis individuais
# FIREBASE_PROJECT_ID=your_project_id_here
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ====================================================
# Modo de Emergência (desabilitado por padrão)
# ====================================================
# ATENÇÃO: NUNCA comite o arquivo .env real no repositório!
# O .env.example é o único arquivo de configuração que deve ser versionado.

# Como obter as configurações do Firebase:
# 1. Acesse o Firebase Console (https://console.firebase.google.com)
# 2. Crie um novo projeto ou acesse um existente
# 3. Vá em Configurações do projeto > Configurações gerais
# 4. Na seção "Seus aplicativos", adicione um aplicativo web
# 5. Copie as configurações geradas aqui
