# Configurações do Firebase
# Copie este arquivo para .env e substitua pelos seus valores reais

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# ATENÇÃO: NUNCA comite o arquivo .env real no repositório!
# O .env.example é o único arquivo de configuração que deve versionado.

# Modo de emergência para criar o primeiro administrador
# Defina como 'true' APENAS para criar o primeiro admin,
# depois remova ou mude para 'false'.
# VITE_ALLOW_EMERGENCY_ADMIN=true

# Como obter estas configurações:
# 1. Acesse o Firebase Console (https://console.firebase.google.com)
# 2. Crie um novo projeto ou acesse um existente
# 3. Vá em Configurações do projeto > Configurações gerais
# 4. Na seção "Seus aplicativos", adicione um aplicativo web
# 5. Copie as configurações geradas aqui
